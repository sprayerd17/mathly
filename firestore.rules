rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // New accounts must always start with every child on the free tier —
      // paid tiers are granted only by the Paystack webhook (via the
      // Firebase Admin SDK, which bypasses these rules entirely). This closes
      // the registration-time exploit where a client could otherwise create
      // itself directly into a paid tier. The key allowlist below closes the
      // wider version of that hole: without it, create only checked
      // childPlans/subscriptionStatus, leaving every other server-only field
      // (paystackCustomerCode, accessUntil, referredBy, pastDueSince, etc.)
      // completely unconstrained at document creation — a fresh account
      // could be created with an arbitrary paystackCustomerCode, which the
      // renewal webhook's customer_code lookup (limit(1)) would then treat
      // as authoritative if the real value ever leaked. Only the exact
      // fields register() actually writes are allowed, and every one of
      // them that's server-managed must be its safe creation-time default.
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly([
                         'name', 'email', 'childPlans', 'subscriptionStatus',
                         'paystackCustomerCode', 'paystackSubscriptionCode', 'paystackEmailToken',
                         'paystackPlanCode', 'paystackFounding', 'pendingChildPlans',
                         'lastPaymentDate', 'lastPaymentAmount', 'accessUntil',
                         'children', 'refCode', 'activeChildIndex', 'createdAt'
                       ])
                    && request.resource.data.subscriptionStatus == 'none'
                    && request.resource.data.keys().hasAll(['childPlans'])
                    && request.resource.data.childPlans.size() == request.resource.data.children.size()
                    && !request.resource.data.childPlans.hasAny(['pro', 'max'])
                    && request.resource.data.paystackCustomerCode == null
                    && request.resource.data.paystackSubscriptionCode == null
                    && request.resource.data.paystackEmailToken == null
                    && request.resource.data.paystackPlanCode == null
                    && request.resource.data.paystackFounding == null
                    && request.resource.data.pendingChildPlans == null
                    && request.resource.data.lastPaymentDate == null
                    && request.resource.data.lastPaymentAmount == null
                    && request.resource.data.accessUntil == null;

      // Billing fields are server-only from this point on — only the
      // Paystack webhook (Admin SDK) may change them. childPlans (each child's tier)
      // is included here too — it's a whole top-level field rather than a
      // sub-field of each child specifically so it can be locked down the
      // same simple way, since there's no clean way to protect just one
      // sub-field of an array-of-maps element while leaving the rest
      // (name/grade/language) freely editable. Growing the family with a new
      // child goes through /api/family/add-child (Admin SDK) for the same
      // reason — it needs to append a 'free' entry to childPlans too.
      // referredBy is also server-only: it's attached once, right after
      // registration, by /api/referral/attach (Admin SDK) — never settable
      // or overwritable by the client itself, so a user can't fake who
      // referred them. refCode is protected too, despite being client-set at
      // creation: without this, a client could overwrite it to someone
      // else's code, and /api/referral/attach's query for that code would
      // then credit whichever doc Firestore returns first — a referral
      // hijack. It's permanent once created, same as an identity field.
      // Everything else the client already legitimately writes (children,
      // activeChildIndex, name, initial) stays freely writable.
      // freeSessionClaimed (index-aligned with children) is set once per
      // child, server-side, by /api/sessions/book the first time that child
      // claims its one free live-session booking — never client-settable,
      // same reasoning as the billing fields above.
      // pastDueSince/dunningStage drive the dunning cron's follow-up cadence
      // for failed renewals — same server-only reasoning as the other
      // billing fields.
      // paystackPlanCode/paystackFounding are set once by the webhook's
      // signup branch (via pendingPlanCode/pendingFounding) and only change
      // again through another server round-trip — /api/paystack/downgrade-child
      // (Admin SDK) is the only other writer of childPlans besides the
      // webhook and add-child, and it never touches these two fields itself.
      // aiUsage is the same server-only pattern as testAnalysisUsage above —
      // written only by /api/ai-assistant (Admin SDK) so a client can't
      // reset its own monthly counter.
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['childPlans', 'subscriptionStatus',
                                  'paystackCustomerCode', 'paystackSubscriptionCode', 'paystackEmailToken',
                                  'paystackPlanCode', 'pendingPlanCode', 'paystackFounding',
                                  'pendingChildPlans', 'pendingFounding', 'pendingAmount', 'pendingSince',
                                  'lastPaymentDate', 'lastPaymentAmount', 'accessUntil',
                                  'referredBy', 'refCode', 'freeSessionClaimed',
                                  'pastDueSince', 'dunningStage',
                                  'testAnalysisUsage', 'aiUsage']);

      allow delete: if false;
    }

    // Saved Test Analysis reports — one doc per analysis a Max student
    // chooses to keep. Written directly by the client (not the Admin SDK):
    // running the analysis itself is server-gated by /api/analyse-test (tier
    // check + usage limit), but saving the finished report back is a plain
    // own-uid write, same trust level as the rest of this user's own data.
    match /users/{userId}/testAnalysisReports/{reportId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['grade', 'date', 'report', 'imageCount'])
                    && request.resource.data.grade is number
                    && request.resource.data.grade >= 4 && request.resource.data.grade <= 12
                    && request.resource.data.date is timestamp
                    && request.resource.data.report is string
                    && request.resource.data.report.size() <= 20000
                    && request.resource.data.imageCount is number;
      allow update, delete: if false;
    }

    // Practice-activity completions — one doc per finished practice
    // set/section/quiz attempt, written directly by the client the moment a
    // student finishes answering (see TopicTabs.tsx). Best-effort and
    // append-only: nothing here gates access or billing, so a failed write
    // just means that one attempt isn't reflected on the dashboard — never
    // worth blocking the student's practice session over.
    // Deletes are allowed (own-uid only) for the dashboard's explicit
    // "reset all attempts for this topic" action — a deliberate, separate
    // action from the in-session "Try again" reset, which never touches
    // Firestore at all.
    match /users/{userId}/activityLog/{activityId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['childIndex', 'grade', 'topicSlug', 'activityType', 'setName', 'score', 'total', 'completedAt'])
                    && request.resource.data.childIndex is int && request.resource.data.childIndex >= 0
                    && request.resource.data.grade is number
                    && request.resource.data.grade >= 4 && request.resource.data.grade <= 12
                    && request.resource.data.topicSlug is string
                    && request.resource.data.topicSlug.size() > 0 && request.resource.data.topicSlug.size() <= 100
                    && request.resource.data.activityType in ['practiceSet', 'sectionPractice', 'openPractice']
                    && (request.resource.data.setName is string || request.resource.data.setName == null)
                    && request.resource.data.score is number && request.resource.data.score >= 0
                    && request.resource.data.total is number && request.resource.data.total > 0
                    && request.resource.data.score <= request.resource.data.total
                    && request.resource.data.completedAt is timestamp;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // "Mark as Studied" toggle for the Study Guide tab — one doc per
    // child+grade+topic (deterministic id, so re-marking just overwrites
    // rather than piling up documents). Separate from activityLog, which is
    // append-only attempt history for practice, since this is a single
    // current-state toggle instead.
    match /users/{userId}/studyProgress/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['childIndex', 'grade', 'topicSlug', 'studied', 'markedAt'])
                    && request.resource.data.childIndex is int && request.resource.data.childIndex >= 0
                    && request.resource.data.grade is number
                    && request.resource.data.grade >= 4 && request.resource.data.grade <= 12
                    && request.resource.data.topicSlug is string
                    && request.resource.data.topicSlug.size() > 0 && request.resource.data.topicSlug.size() <= 100
                    && request.resource.data.studied is bool
                    && request.resource.data.markedAt is timestamp;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // One record per successful referral attachment, written only by
    // /api/referral/attach (Admin SDK) right after the referred friend
    // registers. Deliberately a separate collection rather than exposing
    // other users' full profiles to the referrer — a referrer can only ever
    // read their own referral records, never the referred friend's account.
    match /referrals/{docId} {
      allow read: if request.auth != null && resource.data.referrerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Waitlist signups (coming-soon page) — anyone can add their email,
    // nobody can read, edit, or delete it via the client. View/export the
    // list from the Firebase Console instead.
    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$')
                    && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if false;
    }

    // Paystack webhook audit log — one doc per event received (accepted,
    // failed or rejected), written only by /api/paystack/webhook (Admin
    // SDK). The external admin dashboard reads these via the Admin SDK too,
    // so clients never touch this collection.
    match /payments/{docId} {
      allow read, write: if false;
    }

    // Contact-form requests — create-only from the public site, same
    // write-only pattern as /waitlist. Reviewed and status-managed from the
    // admin dashboard (Admin SDK).
    match /requests/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'grade', 'language', 'requestType', 'description', 'status', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$')
                    && request.resource.data.grade is number
                    && request.resource.data.language in ['en', 'af']
                    && request.resource.data.requestType is string
                    && request.resource.data.description is string
                    && request.resource.data.description.size() <= 5000
                    && request.resource.data.status == 'unreviewed'
                    && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if false;
    }

    // Admin-managed settings (founding-spot counters etc.) — written by the
    // Paystack webhook, checkout enforcement and the admin dashboard, all via the
    // Admin SDK.
    match /settings/{docId} {
      allow read, write: if false;
    }

    // Frozen monthly metrics snapshots, written only by the dashboard's
    // scheduled cron (Admin SDK, shared-secret auth — see
    // mathly-dashboard/app/api/cron/metrics-snapshot).
    match /metricsSnapshots/{docId} {
      allow read, write: if false;
    }

    // Live sessions scheduled from the admin dashboard. Fully closed to
    // clients: session docs carry the Google Meet link, the teacher's private
    // notes and attendance — none of which may leak. The public listing is
    // served sanitized by /api/sessions/list (Admin SDK), and paid students
    // get the Meet link copied onto their own booking doc.
    match /sessions/{docId} {
      allow read, write: if false;
    }

    // Session bookings — created only by /api/sessions/book and confirmed
    // only by the Paystack webhook (both Admin SDK). A signed-in user can
    // read their own bookings (for "you're booked ✓" state and their Meet
    // link) and nobody else's.
    match /bookings/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Lesson requests — signed-in learners asking for specific topics, and
    // waitlist entries for sessions that filled up (sessionId set). Never
    // consumed or deleted when sessions get scheduled: this collection IS the
    // demand signal the dashboard aggregates. Create-only, own-uid enforced.
    match /lessonRequests/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'grade', 'topic', 'details', 'sessionId', 'createdAt'])
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.grade is number
                    && request.resource.data.topic is string
                    && request.resource.data.topic.size() > 0
                    && request.resource.data.topic.size() <= 200
                    && request.resource.data.details is string
                    && request.resource.data.details.size() <= 2000
                    && (request.resource.data.sessionId is string || request.resource.data.sessionId == null)
                    && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if false;
    }

    // Live-class interest signups. Signed-in users always use their own uid
    // as the document ID — this makes "read/write only my own entry" trivial
    // to enforce and lets the client check whether it already has an entry.
    // Guests (no account yet) write to an auto-generated doc ID with
    // uid == null and can never read anything back, same write-only pattern
    // as /waitlist — view/export guest signups from the Firebase Console.
    match /liveClassInterest/{docId} {
      allow read: if request.auth != null && docId == request.auth.uid;

      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'grades', 'uid', 'createdAt', 'updatedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$')
                    && request.resource.data.grades is list
                    && request.resource.data.grades.size() > 0
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.updatedAt is timestamp
                    && (
                      (request.auth != null && docId == request.auth.uid && request.resource.data.uid == request.auth.uid)
                      || (request.auth == null && request.resource.data.uid == null)
                    );

      // Only the signed-in owner can update their own doc, and only to
      // refresh grades/updatedAt — never to reassign uid or email to someone
      // else's. Guests can never update (no way to prove they own a doc with
      // no auth to check against).
      allow update: if request.auth != null && docId == request.auth.uid
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == resource.data.email;

      allow delete: if false;
    }
  }
}
