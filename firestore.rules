rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Waitlist signups (coming-soon page) — anyone can add their email,
    // nobody can read, edit, or delete it via the client. View/export the
    // list from the Firebase Console instead.
    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$')
                    && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if false;
    }
  }
}
